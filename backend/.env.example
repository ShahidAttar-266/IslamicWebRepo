NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
LOG_REQUESTS=true

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/islamicnames?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_placeholder
JWT_REFRESH_SECRET=your_jwt_refresh_secret_placeholder
JWT_EXPIRES_IN=30d



# Other Services
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CLIENT_ID=your_google_client_id_placeholder
REDIS_URL=redis://localhost:6379
SENDGRID_API_KEY=SG.your_sendgrid_key_placeholder
FROM_EMAIL=noreply@islamicnames.in