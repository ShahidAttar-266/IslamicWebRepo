NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
LOG_REQUESTS=true

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/islamicnames?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_YEARLY=price_yearly_id

# Other Services
GOOGLE_CLIENT_ID=your_google_client_id_here
REDIS_URL=redis://...
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@noornames.com
