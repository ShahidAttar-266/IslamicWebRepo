{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://islamic-web-repo.vercel.app/api/v1/names/sitemap.xml"
    },
    {
      "source": "/name/:slug",
      "destination": "/api/v1/names/render/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
